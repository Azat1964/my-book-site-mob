# Скопируйте этот файл в .env и заполните своими реальными значениями
# .env НЕ должен попадать в архивы или систему контроля версий — там пароли!

# PostgreSQL
DB_USER=postgres
DB_HOST=localhost
DB_NAME=your_db_name
DB_PASSWORD=your_db_password
DB_PORT=5432

# Секрет для express-session — любая длинная случайная строка
SESSION_SECRET=replace-with-a-long-random-string

# Токен для доступа к /api/books (POST) и /api/books/:slug/chapters (POST)
# Используется в admin.html — придумайте свой сложный токен вместо примера ниже
ADMIN_TOKEN=replace-with-your-own-admin-token

# Telegram-бот для публикации постов в канал из админки
# Получить токен: напишите @BotFather в Telegram → /newbot
# Бота нужно добавить АДМИНОМ в канал с правом "публиковать сообщения"
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHANNEL=@otets_tuk

# Anthropic API — для ИИ-подбора цитаты и текста анонса из главы для Telegram
# Получить ключ: console.anthropic.com → API Keys → Create Key
# Это ОТДЕЛЬНО от подписки Claude.ai — платится по использованию (по токенам)
ANTHROPIC_API_KEY=...
